{
  "name": "starknet-nft-launchpad",
  "private": true,
  "packageManager": "yarn@3.2.3",
  "workspaces": [
    "packages/cairo",
    "packages/nextjs",
    "packages/mobile"
  ],
  "scripts": {
    "compile": "yarn workspace @launchpad/cairo compile",
    "test": "yarn workspace @launchpad/cairo test",
    "start": "yarn workspace @launchpad/nextjs dev",
    "start:mobile": "yarn workspace @launchpad/mobile start",
    "ios:mobile": "yarn workspace @launchpad/mobile ios",
    "android:mobile": "yarn workspace @launchpad/mobile android",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "contributors:check": "all-contributors check"
  },
  "devDependencies": {
    "all-contributors-cli": "^6.26.1"
  }
}
